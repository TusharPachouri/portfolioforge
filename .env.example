# ─── AI ──────────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create at https://github.com/settings/applications/new
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. Neon: https://neon.tech)
DATABASE_URL=

# ─── Cloudflare R2 — Avatar uploads (optional) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Create at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# ─── Upstash Redis — AI rate limiting (optional) ─────────────────────────────
# Create at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Resend — Transactional email (optional) ─────────────────────────────────
# Get at https://resend.com/api-keys
RESEND_API_KEY=

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com
